  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Judul: N\xE9nuphars et pont japonais\r\nPelukis: Claude Monet\r\nMovement:
    Impresionisme\r\nDeskripsi:\r\n\u201CBunga Teratai dan Jembatan Jepang,\u201D
    yang dilukis pada tahun 1899 oleh Claude Monet, adalah representasi ikonik dari
    kekagumannya terhadap cahaya, warna, dan alam. Karya yang memikat ini merupakan
    bagian dari serangkaian lukisan yang dibuat Monet yang menggambarkan kolam bunga
    teratai terkenalnya di Giverny. Monet sangat terinspirasi oleh seni dan budaya
    Jepang, yang tercermin dalam desain jembatan dan taman di sekitarnya. Lukisan
    ini membuktikan kemampuannya untuk menangkap efek cahaya yang cepat berubah di
    atas air dan warna-warna cerah bunga. Jembatan Jepang, yang dibangun pada tahun
    1895, menjadi elemen sentral dalam lukisannya, melambangkan perpaduan estetika
    Timur dan tradisi seni Barat.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}

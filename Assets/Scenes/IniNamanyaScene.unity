    - target: {fileID: 5621998511447126003, guid: b0c841e3ec3382544b06bcf203fa103c, type: 3}
      propertyPath: m_text
      value: "Judul: La Grenouillere\r\nPelukis: Claude Monet\r\nMovement: Impresionisme\r\nDeskripsi:\r\nSelama
        musim panas tahun 1869, Monet dan Renoir mendirikan kuda-kuda lukis mereka
        di La Grenouill\xE8re, sebuah resor berperahu dan pemandian di Sungai Seine,
        tidak jauh dari Paris. Monet mencatat pada tanggal 25 September, \"Saya memang
        memiliki sebuah mimpi, sebuah lukisan, pemandian La Grenouill\xE8re, yang
        untuknya saya telah membuat beberapa sketsa yang buruk, tetapi itu hanya
        mimpi. Renoir, yang baru saja menghabiskan dua bulan di sini, juga ingin
        melukis lukisan ini.\" Di antara berbagai penggambaran mereka tentang subjek
        tersebut, komposisi ini sangat mirip dengan salah satu karya Renoir di Nationalmuseum,
        Stockholm. \r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6886268650674042242, guid: b0c841e3ec3382544b06bcf203fa103c, type: 3}
      propertyPath: m_LocalPosition.x

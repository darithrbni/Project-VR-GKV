      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 5621998511447126003, guid: b0c841e3ec3382544b06bcf203fa103c, type: 3}
      propertyPath: m_text
      value: "Judul: The Wedding at Cana\r\nPelukis: Paolo Varanese\r\nMovement:
        Renaissance\r\nDeskripsi:\r\nPernikahan di Kana (Italia: Nozze di Cana ,
        1562\u20131563), karya Paolo Veronese , adalah lukisan representasional yang
        menggambarkan kisah Alkitab tentang Pernikahan di Kana , di mana Yesus secara
        ajaib mengubah air menjadi anggur merah ( Yohanes 2 :1\u201311). Dibuat dalam
        gaya Mannerisme (1520\u20131600) dari akhir Renaisans , lukisan minyak berformat
        besar (6,77 m \xD7 9,94 m atau 22 kaki 3 inci \xD7 32 kaki 7 inci)mencakup
        cita-cita gaya harmoni komposisi, seperti yang dipraktikkan oleh para seniman
        Leonardo , Raphael , dan Michelangelo . Seni Renaisans Tinggi (1490\u20131527)
        menekankan figur manusia dengan proporsi ideal, komposisi seimbang, dan keindahan,
        sedangkan Mannerisme melebih-lebihkan cita-cita Renaisans \u2013 figur, cahaya,
        dan warna \u2013 dengan pengaturan asimetris dan elegan yang tidak wajar
        yang dicapai dengan meratakan ruang lukisan dan mendistorsi figur manusia
        sebagai prasangka ideal dari subjek, bukan sebagai representasi realistis.
        Ketegangan visual di antara elemen-elemen lukisan dan ketidakstabilan tematik
        di antara figur manusia dalam Perjamuan Pernikahan di Kana berasal dari penerapan
        teknik artistik Veronese, penyertaan kode dan simbolisme budaya yang canggih
        (sosial, religius, teologis), yang menyajikan kisah alkitabiah yang relevan
        bagi penonton Renaisans dan penonton kontemporer.\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 6886268650674042242, guid: b0c841e3ec3382544b06bcf203fa103c, type: 3}
      propertyPath: m_LocalPosition.x
      value: 14.5
      objectReference: {fileID: 0}

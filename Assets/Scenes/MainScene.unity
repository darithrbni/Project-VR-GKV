    - target: {fileID: 5236836701296059180, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_SizeDelta.x
      value: 340
      objectReference: {fileID: 0}
    - target: {fileID: 5561586740601093287, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_SizeDelta.x
      value: 340
      objectReference: {fileID: 0}
    - target: {fileID: 8161327744406318945, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_Name
      value: PaintingInteractableNew (1)
      objectReference: {fileID: 0}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_text
      value: "\n\n\nDeskripsi:\r\nPernikahan di Kana (Italia: Nozze di Cana , 1562\u20131563),
        karya Paolo Veronese , adalah lukisan representasional yang menggambarkan
        kisah Alkitab tentang Pernikahan di Kana , di mana Yesus secara ajaib mengubah
        air menjadi anggur merah ( Yohanes 2 :1\u201311). Dibuat dalam gaya Mannerisme
        (1520\u20131600) dari akhir Renaisans , lukisan minyak berformat besar (6,77
        m \xD7 9,94 m atau 22 kaki 3 inci \xD7 32 kaki 7 inci)mencakup cita-cita
        gaya harmoni komposisi, seperti yang dipraktikkan oleh para seniman Leonardo
        , Raphael , dan Michelangelo . Seni Renaisans Tinggi (1490\u20131527) menekankan
        figur manusia dengan proporsi ideal, komposisi seimbang, dan keindahan, sedangkan
        Mannerisme melebih-lebihkan cita-cita Renaisans \u2013 figur, cahaya, dan
        warna \u2013 dengan pengaturan asimetris dan elegan yang tidak wajar yang
        dicapai dengan meratakan ruang lukisan dan mendistorsi figur manusia sebagai
        prasangka ideal dari subjek, bukan sebagai representasi realistis. Ketegangan
        visual di antara elemen-elemen lukisan dan ketidakstabilan tematik di antara
        figur manusia dalam Perjamuan Pernikahan di Kana berasal dari penerapan teknik
        artistik Veronese, penyertaan kode dan simbolisme budaya yang canggih (sosial,
        religius, teologis), yang menyajikan kisah alkitabiah yang relevan bagi penonton
        Renaisans dan penonton kontemporer.\r"
      objectReference: {fileID: 0}

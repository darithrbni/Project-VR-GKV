    - target: {fileID: 4875054922105549735, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: onPlayerEnterZone.m_PersistentCalls.m_Calls.Array.data[1].m_Arguments.m_ObjectArgumentAssemblyTypeName
      value: UnityEngine.Object, UnityEngine
      objectReference: {fileID: 0}
    - target: {fileID: 5086310303014392308, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_text
      value: 'Judul: La Grenouillere

        Pelukis: Claude Monet

        Movement:
        Impresionisme














'
      objectReference: {fileID: 0}
    - target: {fileID: 5086310303014392308, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_fontAsset
      value: 
      objectReference: {fileID: 11400000, guid: 21106f572c14c0b4296c62afef4464c1, type: 2}
    - target: {fileID: 5086310303014392308, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_sharedMaterial
      value: 
      objectReference: {fileID: -4816301792969835693, guid: 21106f572c14c0b4296c62afef4464c1, type: 2}
    - target: {fileID: 5086310303014392308, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_hasFontAssetChanged
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 8161327744406318945, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_Name
      value: PaintingInteractableNew (2)
      objectReference: {fileID: 0}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_text
      value: "\n\n\nDeskripsi:\r\nSelama musim panas tahun 1869, Monet dan Renoir
        mendirikan kuda-kuda lukis mereka di La Grenouill\xE8re, sebuah resor berperahu
        dan pemandian di Sungai Seine, tidak jauh dari Paris. Monet mencatat pada
        tanggal 25 September, \"Saya memang memiliki sebuah mimpi, sebuah lukisan,
        pemandian La Grenouill\xE8re, yang untuknya saya telah membuat beberapa sketsa
        yang buruk, tetapi itu hanya mimpi. Renoir, yang baru saja menghabiskan dua
        bulan di sini, juga ingin melukis lukisan ini.\" Di antara berbagai penggambaran
        mereka tentang subjek tersebut, komposisi ini sangat mirip dengan salah satu
        karya Renoir di Nationalmuseum, Stockholm. \r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_fontAsset
      value: 
      objectReference: {fileID: 11400000, guid: 21106f572c14c0b4296c62afef4464c1, type: 2}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_sharedMaterial
      value: 
      objectReference: {fileID: -4816301792969835693, guid: 21106f572c14c0b4296c62afef4464c1, type: 2}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_hasFontAssetChanged
      value: 0

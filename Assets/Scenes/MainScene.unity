      objectReference: {fileID: 0}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_text
      value: "\n\n\nDeskripsi:\r\nKarya gitar Pablo Picasso tahun 1913 terutama terwujud
        sebagai kolase dan lukisan Kubisme Sintetis dengan tekstur yang sangat kaya,
        seperti Glass, Guitar, dan Bottle and Guitar (C\xE9ret). Alih-alih menggambarkan
        adegan realistis, karya seni ini membongkar dan menyusun kembali instrumen
        tersebut menggunakan campuran potongan dan tempelan koran, kertas dinding
        berpola, arang, dan tinta untuk menantang batasan tradisional bentuk dan
        ruang\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}

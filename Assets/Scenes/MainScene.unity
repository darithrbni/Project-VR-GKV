      objectReference: {fileID: 0}
    - target: {fileID: 5086310303014392308, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_text
      value: "Judul: Golconda\r\nPelukis: Ren\xE9 Magritte\r\nMovement: Surealisme\r\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"
      objectReference: {fileID: 0}
    - target: {fileID: 5086310303014392308, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_fontAsset
      value: 
      objectReference: {fileID: 11400000, guid: 21106f572c14c0b4296c62afef4464c1, type: 2}
    - target: {fileID: 5086310303014392308, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_sharedMaterial
      value: 
      objectReference: {fileID: -4816301792969835693, guid: 21106f572c14c0b4296c62afef4464c1, type: 2}
    - target: {fileID: 5086310303014392308, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_hasFontAssetChanged
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 5236836701296059180, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_SizeDelta.x
      value: 290
      objectReference: {fileID: 0}
    - target: {fileID: 5561586740601093287, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_SizeDelta.x
      value: 290
      objectReference: {fileID: 0}
    - target: {fileID: 8161327744406318945, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_Name
      value: PaintingInteractableNew (4)
      objectReference: {fileID: 0}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_text
      value: "\n\n\nDeskripsi:\r\nKarya ini menggambarkan pemandangan bangunan beratap
        merah dan langit yang sebagian besar biru dan berawan sebagian, dengan udara
        dipenuhi oleh puluhan pria yang hampir identik mengenakan mantel gelap dan
        topi bowler , umumnya menghadap ke arah penonton. Para pria tersebut diposisikan
        seolah-olah berdiri, dan mungkin sedang jatuh, naik, atau diam di udara;
        tidak ada gerakan atau pergerakan yang tersirat. Mereka berjarak sama dalam
        kisi tiga dimensi , dan mundur ke belakang dalam lapisan kisi belah ketupat.
        Golconda terinspirasi oleh foto-foto tentara yang terjun payung selama Perang
        Dunia I. Dalam lukisan itu, ia membayangkan kembali adegan tersebut dengan
        pria-pria berpakaian sama mengenakan topi bowler. Magritte tinggal di lingkungan
        pinggiran kota yang serupa , dan berpakaian dengan cara yang serupa. Topi
        bowler merupakan ciri umum dari sebagian besar karyanya, dan muncul dalam
        lukisan-lukisan seperti The Son of Man (1964). \r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_fontAsset
      value: 
      objectReference: {fileID: 11400000, guid: 21106f572c14c0b4296c62afef4464c1, type: 2}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}

      value: 340
      objectReference: {fileID: 0}
    - target: {fileID: 5561586740601093287, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_SizeDelta.x
      value: 340
      objectReference: {fileID: 0}
    - target: {fileID: 6784701691589995197, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_AnchoredPosition.y
      value: -33.4
      objectReference: {fileID: 0}
    - target: {fileID: 6889212237806016261, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_LocalPosition.y
      value: -0.925
      objectReference: {fileID: 0}
    - target: {fileID: 8161327744406318945, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_Name
      value: PaintingInteractableNew (3)
      objectReference: {fileID: 0}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_text
      value: "\n\n\nDeskripsi:\r\nLukisan ini mengolah kembali elemen-elemen dari
        karya Matisse tahun 1897, Gurun. Meskipun karya tersebut bergaya Impresionis,
        warna-warna intens pada lukisan selanjutnya lebih konsisten dengan Fauvisme.
        Warna merah ruangan kontras dengan warna hijau gelap lanskap yang digambarkan
        di luar jendela. Pusaran biru gelap yang menghiasi taplak meja dan dinding
        kontras dengan banyaknya warna merah yang kaya. \r\nMatisse sengaja mempertahankan
        kualitas realistis objek bahkan ketika ia bereksperimen dengan warna lingkungan
        sekitarnya. Misalnya, lemon di atas meja berwarna kuning dan mempertahankan
        bentuk dan ukuran yang realistis.\r\nWanita dalam lukisan memberikan kesan
        realisme dalam lukisan. Wanita tersebut proporsional dengan meja. Wanita
        tersebut memberikan konteks waktu lukisan dengan pakaian yang dikenakannya
        dan tindakan yang sedang dilakukannya. Dalam buku Matisse: The Man and His
        Art , Katharine Kuh membandingkan Harmony in Red dengan lukisan Matisse Bathers
        with a Turtle , yang diselesaikan antara tahun 1907 dan 1908. Lengkungan
        tubuh dalam Bathers with a Turtle mirip dengan pose wanita.\n"
      objectReference: {fileID: 0}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_fontAsset
      value: 
      objectReference: {fileID: 11400000, guid: 21106f572c14c0b4296c62afef4464c1, type: 2}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_sharedMaterial
      value: 
      objectReference: {fileID: -4816301792969835693, guid: 21106f572c14c0b4296c62afef4464c1, type: 2}
    - target: {fileID: 9078484445980704400, guid: 1c4a22e9b7bfb1848b6bba2056ed2250, type: 3}
      propertyPath: m_hasFontAssetChanged
      value: 0
      objectReference: {fileID: 0}
